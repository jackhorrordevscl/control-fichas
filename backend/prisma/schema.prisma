// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  role         Role      @default(THERAPIST)
  mfaSecret    String?
  mfaEnabled   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  patients          Patient[]
  consultations     Consultation[]
  auditLogs         AuditLog[]
  patientEdits      PatientHistory[]      @relation("PatientEdits")
  sharedFiles       SharedFile[]          @relation("UploadedFiles")
  consultationEdits ConsultationHistory[] @relation("ConsultationEdits")
}

enum Role {
  DIRECTOR
  COORDINATOR
  THERAPIST
  ADMIN
}

model Patient {
  id                    String    @id @default(uuid())
  fullName              String
  rut                   String    @unique
  birthDate             DateTime
  occupation            String?
  address               String?
  phone                 String?
  email                 String?
  emergencyContactName  String?
  emergencyContactPhone String?
  treatingPsychiatrist  String?
  treatingDoctor        String?
  isActive              Boolean   @default(true)
  deletedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  consentSigned         Boolean   @default(false)
  telemedConsentSigned  Boolean   @default(false)
  notificationsConsent  Boolean   @default(false)

  consents Consent[]
  dataSubjectRequests DataSubjectRequest[]

  therapistId   String
  therapist     User              @relation(fields: [therapistId], references: [id])
  consultations Consultation[]
  documents     PatientDocument[]
  history       PatientHistory[]
}

model Consent {
  id        String      @id @default(uuid())
  patientId String
  patient   Patient     @relation(fields: [patientId], references: [id])
  documentId String?
  document  PatientDocument? @relation(fields: [documentId], references: [id])
  type      ConsentType
  version   String
  textHash  String? // hash or reference to the stored consent text/document
  grantedAt DateTime    @default(now())
  grantedBy String? // user id who recorded the consent
  method    String? // e.g., ELECTRONIC, IN_PERSON
  revokedAt DateTime?
  revokedBy String?
  reason    String?
  metadata  Json?

  createdAt DateTime @default(now())

  @@index([patientId])
  @@index([documentId])
}

enum ConsentType {
  INFORMED_CONSENT
  TELEMEDICINE
  OTHER
}

model DataSubjectRequest {
  id              String                     @id @default(uuid())
  patientId       String
  patient         Patient                    @relation(fields: [patientId], references: [id])
  type            DataSubjectRequestType
  status          DataSubjectRequestStatus   @default(PENDING)
  details         String?
  evidence        Json?
  requestedBy     String?
  resolvedAt      DateTime?
  resolvedBy      String?
  resolutionNote  String?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  @@index([patientId])
}

enum DataSubjectRequestType {
  ACCESS
  RECTIFICATION
  REVOCATION
  OPPOSITION
  EXPORT
}

enum DataSubjectRequestStatus {
  PENDING
  RESOLVED
  REJECTED
  CLOSED
}

model PatientDocument {
  id             String        @id @default(uuid())
  patientId      String
  patient        Patient       @relation(fields: [patientId], references: [id])
  consultationId String?
  consultation   Consultation? @relation(fields: [consultationId], references: [id])
  consents       Consent[]
  type           DocumentType
  fileName       String
  storagePath    String
  contentHash    String?
  encrypted      Boolean       @default(false)
  encDataKey     String?
  encDataKeyIv   String?
  encDataKeyTag  String?
  iv             String?
  tag            String?
  uploadedAt     DateTime      @default(now())
  uploadedBy     String
}

enum DocumentType {
  INFORMED_CONSENT
  TELEMED_AGREEMENT
  PATIENT_REPORT
  CONSULTATION_ATTACHMENT
  OTHER
}

model Consultation {
  id                String        @id @default(uuid())
  patientId         String
  patient           Patient       @relation(fields: [patientId], references: [id])
  therapistId       String
  therapist         User          @relation(fields: [therapistId], references: [id])
  sessionDate       DateTime
  consultReason     String
  intervention      String
  agreements        String?
  nextSessionDate   DateTime?
  sessionType       SessionType   @default(IN_PERSON)
  createdAt         DateTime      @default(now())
  scheduledAt       DateTime
  reminderSent      Boolean       @default(false)
  patientRut        String
  isCurrent         Boolean       @default(true)
  previousVersionId String?       @unique
  previousVersion   Consultation? @relation("ConsultationVersionChain", fields: [previousVersionId], references: [id])
  nextVersion       Consultation? @relation("ConsultationVersionChain")

  history   ConsultationHistory[]
  documents PatientDocument[]
}

enum SessionType {
  IN_PERSON
  TELEMED
}

model AuditLog {
  id            String      @id @default(uuid())
  userId        String?
  user          User?       @relation(fields: [userId], references: [id])
  action        AuditAction
  resource      String
  resourceId    String
  detail        String?
  ipAddress     String?
  userAgent     String?
  correlationId String?
  statusCode    Int?
  createdAt     DateTime    @default(now())
}

enum AuditAction {
  LOGIN
  LOGIN_FAILED
  LOGOUT
  VIEW
  CREATE
  UPDATE
  SOFT_DELETE
  EXPORT_PDF
  DOCUMENT_UPLOAD
  DOCUMENT_DOWNLOAD
  CONSENT_CREATED
  CONSENT_REVOKED
  ACCESS_DENIED
  ERROR
  MFA_ENABLED
  MFA_FAILED
}

model SharedFile {
  id           String       @id @default(cuid())
  name         String // Nombre descriptivo del archivo
  originalName String // Nombre original del archivo
  filename     String // Nombre en disco
  path         String // Ruta en servidor
  mimetype     String
  size         Int
  category     FileCategory @default(GENERAL)
  description  String?
  uploadedBy   User         @relation("UploadedFiles", fields: [uploadedById], references: [id])
  uploadedById String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  isActive     Boolean      @default(true)

  @@map("shared_files")
}

enum FileCategory {
  LIBRO
  PLANTILLA
  IMAGEN
  FORMULARIO
  PROTOCOLO
  GENERAL
}

model PatientHistory {
  id          String   @id @default(uuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  changedById String
  changedBy   User     @relation("PatientEdits", fields: [changedById], references: [id])
  changedAt   DateTime @default(now())
  reason      String
  snapshot    Json
  diff        Json
}

model ConsultationHistory {
  id             String       @id @default(uuid())
  consultationId String
  consultation   Consultation @relation(fields: [consultationId], references: [id])
  editedById     String
  editedBy       User         @relation("ConsultationEdits", fields: [editedById], references: [id])
  editedAt       DateTime     @default(now())
  reason         String
  snapshot       Json
}
